{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "checks": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true,
      "type": "array"
    },
    "commit_sha": {
      "pattern": "^[0-9a-fA-F]{40}$",
      "type": "string"
    },
    "ledger_id": {
      "const": "CRG3",
      "type": "string"
    },
    "local_head": {
      "pattern": "^[0-9a-fA-F]{40}$",
      "type": "string"
    },
    "local_working_tree": {
      "const": "clean",
      "type": "string"
    },
    "repository": {
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?/[A-Za-z0-9._-]+$",
      "type": "string"
    },
    "repository_binding_source": {
      "pattern": "^(origin fetch remote|explicit allowed repository set)$",
      "type": "string"
    },
    "run_attempt": {
      "minimum": 1,
      "type": "integer"
    },
    "run_id": {
      "pattern": "^[0-9]+$",
      "type": "string"
    },
    "run_url": {
      "pattern": "^https://github\\.com/[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?/[A-Za-z0-9._-]+/actions/runs/[0-9]+/?$",
      "type": "string"
    },
    "runtime_lock": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "const": "requirements.lock",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256"
      ],
      "type": "object"
    },
    "sbom_artifact": {
      "const": "production-sbom",
      "type": "string"
    },
    "sbom_artifact_metadata": {
      "additionalProperties": false,
      "properties": {
        "artifact_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "component_count": {
          "minimum": 1,
          "type": "integer"
        },
        "download_url": {
          "pattern": "^https://api\\.github\\.com/repos/[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?/[A-Za-z0-9._-]+/actions/artifacts/[0-9]+/zip$",
          "type": "string"
        },
        "download_size_in_bytes": {
          "maximum": 5242880,
          "minimum": 1,
          "type": "integer"
        },
        "id": {
          "minimum": 1,
          "type": "integer"
        },
        "size_in_bytes": {
          "maximum": 5242880,
          "minimum": 1,
          "type": "integer"
        },
        "sbom_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "artifact_sha256",
        "component_count",
        "download_url",
        "download_size_in_bytes",
        "id",
        "size_in_bytes",
        "sbom_sha256"
      ],
      "type": "object"
    },
    "schema": {
      "const": "docs/CRG3_EVIDENCE_SCHEMA.json",
      "type": "string"
    },
    "schema_version": {
      "const": 9,
      "type": "integer"
    },
    "verified_date": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "type": "string"
    },
    "workflow": {
      "additionalProperties": false,
      "properties": {
        "job": {
          "const": "readiness",
          "type": "string"
        },
        "live_execution_env": {
          "const": "0",
          "type": "string"
        },
        "name": {
          "const": "Production Readiness",
          "type": "string"
        },
        "path": {
          "const": ".github/workflows/production-readiness.yml",
          "type": "string"
        },
        "sbom_path": {
          "const": "build/security/sbom.cdx.json",
          "type": "string"
        },
        "wrapper_command": {
          "const": "python tools/security/production_readiness.py --profile ci",
          "type": "string"
        }
      },
      "required": [
        "job",
        "live_execution_env",
        "name",
        "path",
        "sbom_path",
        "wrapper_command"
      ],
      "type": "object"
    }
  },
  "required": [
    "checks",
    "commit_sha",
    "ledger_id",
    "local_head",
    "local_working_tree",
    "repository",
    "repository_binding_source",
    "run_attempt",
    "run_id",
    "run_url",
    "runtime_lock",
    "sbom_artifact",
    "sbom_artifact_metadata",
    "schema",
    "schema_version",
    "verified_date",
    "workflow"
  ],
  "type": "object"
}
